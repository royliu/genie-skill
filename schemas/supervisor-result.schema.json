{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "supervisor-result.schema.json",
  "title": "Supervisor result (the ONLY content of a supervisor's final message)",
  "type": "object",
  "required": ["module", "status", "summary", "criteria", "escalations"],
  "properties": {
    "module": { "type": "string" },
    "status": { "enum": ["done", "needs-input", "blocked", "failed"] },
    "summary": { "type": "string" },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "met", "evidence"],
        "properties": {
          "criterion": { "type": "string" },
          "met": { "type": "boolean" },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["what", "why"],
        "properties": {
          "what": { "type": "string" },
          "why": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "escalations": { "type": "array", "items": { "$ref": "escalation.schema.json" } },
    "iterations_used": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
